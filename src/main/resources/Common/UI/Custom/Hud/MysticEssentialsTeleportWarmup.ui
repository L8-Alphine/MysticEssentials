// Mystic Essentials teleport warmup indicator.
//
// Matches the MysticVanish HUD placement so short status text appears above the
// hotbar/mana region without opening a modal page.
Group #TeleportWarmupHudRoot {
  Anchor: (Bottom: 230, Left: 0, Right: 0, Height: 40);
  LayoutMode: CenterMiddle;

  Group #TeleportWarmupPanel {
    Background: #000000(0.35);
    Padding: (Horizontal: 18, Vertical: 6);
    LayoutMode: CenterMiddle;

    Label #Status {
      Style: (FontSize: 18, TextColor: #55ffff, RenderBold: true, Alignment: Center, VerticalAlignment: Center);
      Text: "Teleporting in 3...";
    }
  }
}
