$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 560, Height: 620);

  #Title {
    Group {
      $C.@Title {
        @Text = "Tutorial";
      }
    }
  }

  #Content {
    LayoutMode: Top;

    Label #PageTitle {
      Anchor: (Height: 30, Bottom: 4);
      Style: (FontSize: 22, RenderBold: true, TextColor: #ffffff);
      Text: "";
    }

    Label #PageSubtitle {
      Anchor: (Height: 40, Bottom: 10);
      Style: (FontSize: 14, TextColor: #9fb0c4, Wrap: true);
      Text: "";
    }

    Group #ContentList {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      Padding: (Right: 10);
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
    }

    Group #ButtonList {
      LayoutMode: Top;
      Anchor: (Top: 10);
      Padding: (Right: 10);
    }
  }
}
