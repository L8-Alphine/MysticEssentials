$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 560, Height: 560);

  #Title {
    Group {
      $C.@Title {
        @Text = "Manage Temporary Channel";
      }
    }
  }

  #Content {
    LayoutMode: Top;

    Group {
      Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);
      LayoutMode: Top;
      Padding: (Full: 16);
      Anchor: (Bottom: 12);

      Label #ManageChannelName {
        Anchor: (Bottom: 8);
        Style: (FontSize: 20, RenderBold: true, TextColor: #ffffff);
        Text: "channel";
      }

      Label #ManageExpiry {
        Anchor: (Bottom: 12);
        Style: (FontSize: 13, TextColor: #96a9be);
        Text: "";
      }

      Label {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
        Text: "Password (blank = open channel)";
      }
      $C.@TextField #ManagePasswordInput {
        @Anchor = (Height: 40, Bottom: 12);
        PlaceholderText: "No password";
      }

      Label {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
        Text: "Prefix";
      }
      $C.@TextField #ManagePrefixInput {
        @Anchor = (Height: 40);
        PlaceholderText: "e.g. &b[EVENT]";
      }
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 44, Bottom: 10);

      $C.@TextButton #SaveChannelButton {
        @Text = "Save Changes";
        @Anchor = (Width: 190, Right: 8);
      }

      $C.@TertiaryTextButton #BackToChannelsButton {
        @Text = "Back";
        @Anchor = (Width: 120);
      }
    }

    $C.@CancelTextButton #CloseChannelButton {
      @Text = "Close Channel";
      @Anchor = (Width: 200);
    }
  }
}
