// Text content row for tutorial pages. Appended per content item:
//   cmd.append("#ContentList", "MysticEssentials/TutorialTextRow.ui")
// and populated by index: cmd.set("#ContentList[i] #Text.Text", ...).

Group #Row {
  LayoutMode: Top;
  Anchor: (Bottom: 8);

  Label #Text {
    Anchor: (Height: 40);
    Style: (FontSize: 14, TextColor: #e6edf5, Wrap: true, VerticalAlignment: Center);
    Text: "";
  }
}
