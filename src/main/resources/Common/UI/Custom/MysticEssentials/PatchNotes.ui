$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 1180, Height: 720);

  #Title {
    Group {
      $C.@Title {
        @Text = "Patch Notes";
      }

      Label #HeaderInfo {
        Anchor: (Top: 8, Right: 14, Width: 260, Height: 24);
        Style: (FontSize: 14, TextColor: #7bd88f, HorizontalAlignment: End, VerticalAlignment: Center);
        Text: "";
      }
    }
  }

  #Content {
    LayoutMode: Left;

    // ===================== Left: patch list =====================
    Group {
      Anchor: (Width: 340);
      LayoutMode: Top;
      Padding: (Right: 12);

      Label {
        Anchor: (Height: 24, Bottom: 8);
        Style: (...$C.@DefaultLabelStyle, FontSize: 14, RenderBold: true, RenderUppercase: true, TextColor: #7fa8d6);
        Text: "Updates";
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 34, Bottom: 8);

        $C.@TextField #SearchInput {
          @Anchor = (Right: 6);
          FlexWeight: 1;
          PlaceholderText: "Search patch notes...";
        }

        $C.@SecondaryTextButton #SearchButton {
          @Text = "Search";
          @Anchor = (Width: 96);
        }
      }

      Label #ListEmpty {
        Anchor: (Height: 40);
        Style: (FontSize: 14, TextColor: #9fb0c4, VerticalAlignment: Center, Wrap: true);
        Text: "No patch notes yet.";
        Visible: false;
      }

      Group #NoteList {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        Padding: (Right: 10);
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
      }
    }

    // ===================== Right: viewer =====================
    Group {
      FlexWeight: 1;
      LayoutMode: Top;
      Padding: (Left: 12);

      Label #PatchTitle {
        Anchor: (Height: 30, Bottom: 4);
        Style: (FontSize: 22, RenderBold: true, TextColor: #ffffff);
        Text: "Patch Notes";
      }

      Label #PatchMeta {
        Anchor: (Height: 18, Bottom: 6);
        Style: (FontSize: 13, TextColor: #96a9be);
        Text: "";
      }

      Label #PatchSummary {
        Anchor: (Height: 34, Bottom: 8);
        Style: (FontSize: 14, TextColor: #c9d6e5, Wrap: true);
        Text: "";
        Visible: false;
      }

      // Category filter buttons (All + configured categories), appended per entry.
      Group #FilterBar {
        Anchor: (Height: 34, Bottom: 8);
        LayoutMode: Left;
      }

      $C.@PanelSeparatorFancy {
        @Anchor = (Bottom: 10);
      }

      Label #ContentEmpty {
        Anchor: (Height: 30);
        Style: (FontSize: 14, TextColor: #9fb0c4, VerticalAlignment: Center, Wrap: true);
        Text: "";
        Visible: false;
      }

      Group #SectionContent {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        Padding: (Right: 10);
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
      }

      // ----- Footer -----
      $C.@PanelSeparatorFancy {
        @Anchor = (Top: 8, Bottom: 8);
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 42);

        Group {
          FlexWeight: 1;
        }

        $C.@SecondaryTextButton #MarkAllButton {
          @Text = "Mark All As Read";
          @Anchor = (Width: 190, Right: 8);
        }

        $C.@TextButton #CloseButton {
          @Text = "Close";
          @Anchor = (Width: 120);
        }
      }
    }
  }
}
