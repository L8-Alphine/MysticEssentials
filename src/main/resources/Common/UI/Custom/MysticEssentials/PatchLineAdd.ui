Group #Row {
  LayoutMode: Top;
  Anchor: (Height: 20);

  Label #Line {
    Anchor: (Full: 0);
    Style: (FontSize: 14, TextColor: #7bd88f, VerticalAlignment: Center);
    Text: "";
  }
}
