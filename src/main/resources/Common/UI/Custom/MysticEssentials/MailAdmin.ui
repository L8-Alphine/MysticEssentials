$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 1320, Height: 760);

  #Title {
    Group {
      $C.@Title {
        @Text = "Mail Admin Center";
      }

      Label #HeaderInfo {
        Anchor: (Top: 8, Right: 14, Width: 300, Height: 24);
        Style: (FontSize: 13, TextColor: #96a9be, HorizontalAlignment: End, VerticalAlignment: Center);
        Text: "";
      }
    }
  }

  #Content {
    LayoutMode: Left;

    // ===================== Composer =====================
    Group {
      Anchor: (Width: 660);
      LayoutMode: Top;
      Padding: (Right: 16);

      Label {
        Anchor: (Height: 22, Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, FontSize: 15, RenderBold: true, RenderUppercase: true, TextColor: #f0b429);
        Text: "Compose Announcement";
      }

      Label {
        Anchor: (Height: 16, Bottom: 4);
        Style: (...$C.@DefaultLabelStyle, FontSize: 12, RenderBold: true, RenderUppercase: true);
        Text: "Subject";
      }

      $C.@TextField #SubjectInput {
        @Anchor = (Height: 34, Bottom: 8);
        PlaceholderText: "Announcement title...";
      }

      Label {
        Anchor: (Height: 16, Bottom: 2);
        Style: (...$C.@DefaultLabelStyle, FontSize: 12, RenderBold: true, RenderUppercase: true);
        Text: "Message";
      }

      $C.@MultilineTextField #BodyInput {
        @Anchor = (Height: 140, Bottom: 8);
        PlaceholderText: "Write your announcement...";
      }

      Label {
        Anchor: (Height: 16, Bottom: 4);
        Style: (...$C.@DefaultLabelStyle, FontSize: 12, RenderBold: true, RenderUppercase: true);
        Text: "Audience";
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 32, Bottom: 4);

        $C.@SecondaryTextButton #AudOnline {
          @Text = "Online";
          @Anchor = (Width: 110, Right: 8);
        }

        $C.@SecondaryTextButton #AudKnown {
          @Text = "All Known";
          @Anchor = (Width: 140, Right: 8);
        }

        $C.@SecondaryTextButton #AudPermission {
          @Text = "Permission";
          @Anchor = (Width: 155, Right: 8);
        }

        $C.@SecondaryTextButton #AudPlayer {
          @Text = "One Player";
          @Anchor = (Width: 150);
        }
      }

      Label #AudienceLabel {
        Anchor: (Height: 16, Bottom: 6);
        Style: (FontSize: 12, TextColor: #f0b429, VerticalAlignment: Center);
        Text: "Delivering to: Online now";
      }

      $C.@TextField #ParamInput {
        @Anchor = (Height: 32, Bottom: 8);
        PlaceholderText: "permission node or player name";
        Visible: false;
      }

      Label #CommandLabel {
        Anchor: (Height: 16, Bottom: 4);
        Style: (...$C.@DefaultLabelStyle, FontSize: 12, RenderBold: true, RenderUppercase: true);
        Text: "Reward commands (; separated) — {player} {uuid}";
      }

      $C.@TextField #CommandInput {
        @Anchor = (Height: 32, Bottom: 8);
        PlaceholderText: "give {player} 1 Diamond; xp add {player} 100";
      }

      Label #RewardHeader {
        Anchor: (Height: 18, Bottom: 4);
        Style: (...$C.@DefaultLabelStyle, FontSize: 12, RenderBold: true, RenderUppercase: true, TextColor: #f0b429);
        Text: "Item rewards (max 9)";
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 34, Bottom: 8);

        $C.@TextField #PickerSearch {
          @Anchor = (Right: 8);
          FlexWeight: 1;
          PlaceholderText: "Search the item registry...";
        }

        $C.@SecondaryTextButton #SearchButton {
          @Text = "Search";
          @Anchor = (Width: 112, Right: 8);
        }

        Label {
          Anchor: (Width: 26, Height: 34);
          Style: (FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center);
          Text: "Qty";
        }

        $C.@TextField #QtyInput {
          @Anchor = (Width: 56, Right: 8);
          Value: "1";
        }

        $C.@CancelTextButton #ClearRewardsButton {
          @Text = "Clear";
          @Anchor = (Width: 100);
        }
      }

      Group {
        FlexWeight: 1;
        LayoutMode: Left;

        Group {
          Anchor: (Width: 300);
          LayoutMode: Top;
          Padding: (Right: 10);

          Label {
            Anchor: (Height: 16, Bottom: 4);
            Style: (FontSize: 12, TextColor: #9fb0c4);
            Text: "Results (click to attach)";
          }

          Label #NoItemsLabel {
            Anchor: (Height: 28);
            Style: (FontSize: 13, TextColor: #9fb0c4, VerticalAlignment: Center);
            Text: "No matching items — search above.";
            Visible: false;
          }

          Group #PickerList {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            Padding: (Right: 10);
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
          }
        }

        Group {
          FlexWeight: 1;
          LayoutMode: Top;
          Padding: (Left: 10);

          Label #DraftLabel {
            Anchor: (Height: 16, Bottom: 4);
            Style: (FontSize: 12, TextColor: #9fb0c4);
            Text: "Attached (0)";
          }

          Group #DraftList {
            FlexWeight: 1;
            LayoutMode: TopScrolling;
            Padding: (Right: 10);
            ScrollbarStyle: $C.@DefaultScrollbarStyle;
          }
        }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 44, Top: 8);

        Group {
          FlexWeight: 1;
        }

        $C.@CancelTextButton #CancelButton {
          @Text = "Close";
          @Anchor = (Width: 100, Right: 8);
        }

        $C.@TextButton #SendButton {
          @Text = "Send Announcement";
          @Anchor = (Width: 200);
        }
      }
    }

    // ===================== History =====================
    Group {
      FlexWeight: 1;
      LayoutMode: Top;
      Padding: (Left: 16);

      Label {
        Anchor: (Height: 22, Bottom: 8);
        Style: (...$C.@DefaultLabelStyle, FontSize: 15, RenderBold: true, RenderUppercase: true);
        Text: "Sent Announcements";
      }

      Label #HistoryEmpty {
        Anchor: (Height: 40);
        Style: (FontSize: 14, TextColor: #9fb0c4, VerticalAlignment: Center, Wrap: true);
        Text: "No announcements sent yet.";
        Visible: false;
      }

      Group #HistoryList {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        Padding: (Right: 10);
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
      }
    }
  }
}
