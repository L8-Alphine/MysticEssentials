// Button row for tutorial pages. Appended per button:
//   cmd.append("#ButtonList", "MysticEssentials/TutorialButtonRow.ui")
// label set by index, click bound on the row root (Button):
//   cmd.set("#ButtonList[i] #ButtonLabel.Text", ...)

Button #Row {
  Anchor: (Height: 46, Bottom: 8);
  LayoutMode: Left;
  Padding: (Left: 12, Right: 12, Top: 6, Bottom: 6);
  Style: (
    Default: (Background: #7a9cc6(0.16)),
    Hovered: (Background: #7a9cc6(0.30)),
    Pressed: (Background: #7a9cc6(0.42))
  );

  Label #ButtonLabel {
    FlexWeight: 1;
    Style: (FontSize: 15, TextColor: #ffffff, RenderBold: true,
            VerticalAlignment: Center, HorizontalAlignment: Center);
    Text: "";
  }
}
