$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 620, Height: 620);

  #Title {
    Group {
      $C.@Title {
        @Text = "Warp Admin";
      }
    }
  }

  #Content {
    LayoutMode: Top;

    Group {
      Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);
      LayoutMode: Top;
      Padding: (Full: 16);
      Anchor: (Bottom: 12);

      Label #AdminHeading {
        Anchor: (Bottom: 10);
        Style: (FontSize: 20, RenderBold: true, TextColor: #ffffff);
        Text: "Warp";
      }

      Label {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
        Text: "Name";
      }
      $C.@TextField #AdminName {
        @Anchor = (Height: 38, Bottom: 10);
        PlaceholderText: "Warp name";
      }

      Label {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
        Text: "Description";
      }
      $C.@TextField #AdminDescription {
        @Anchor = (Height: 38, Bottom: 10);
        PlaceholderText: "Description";
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 38, Bottom: 10);

        $C.@TextField #AdminCost {
          @Anchor = (Right: 8, Width: 140);
          PlaceholderText: "Cost";
        }

        $C.@TextField #AdminPermission {
          @Anchor = ();
          FlexWeight: 1;
          PlaceholderText: "Permission (empty = public)";
        }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 34);

        Label {
          Anchor: (Width: 110);
          Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true, VerticalAlignment: Center);
          Text: "Visibility";
        }

        $C.@DropdownBox #AdminVisibility {
          @Anchor = (Width: 240);
        }
      }
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 44, Bottom: 8);

      $C.@TextButton #SaveHereButton {
        @Text = "Save Warp Here";
        @Anchor = (Width: 220, Right: 8);
      }

      $C.@SecondaryTextButton #SaveDetailsButton {
        @Text = "Save Details";
        @Anchor = (Width: 180);
      }
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 44, Bottom: 14);

      $C.@CancelTextButton #DeleteWarpButton {
        @Text = "Delete Warp";
        @Anchor = (Width: 190);
      }
    }

    $C.@PanelSeparatorFancy {
      @Anchor = (Bottom: 10);
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 44);

      $C.@TertiaryTextButton #BackToWarpsButton {
        @Text = "Back to Warps";
        @Anchor = (Width: 200);
      }
    }
  }
}
