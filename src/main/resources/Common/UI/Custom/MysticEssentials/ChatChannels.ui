$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 940, Height: 640);

  #Title {
    Group {
      $C.@Title {
        @Text = "Chat Channels";
      }
    }
  }

  #Content {
    LayoutMode: Left;

    Group {
      Anchor: (Width: 330);
      LayoutMode: Top;

      Label #CurrentChannelLabel {
        Anchor: (Height: 26, Bottom: 6);
        Style: (FontSize: 14, TextColor: #E8A93B, RenderBold: true, VerticalAlignment: Center);
        Text: "Speaking: global";
      }

      Label #ChannelEmpty {
        Anchor: (Height: 40);
        Style: (FontSize: 14, TextColor: #9fb0c4, VerticalAlignment: Center);
        Text: "No channels available.";
        Visible: false;
      }

      Group #ChannelList {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        Padding: (Right: 10);
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
      }
    }

    Group {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      Padding: (Left: 12);
      ScrollbarStyle: $C.@DefaultScrollbarStyle;

      Group {
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);
        LayoutMode: Top;
        Padding: (Full: 16);
        Anchor: (Bottom: 12);

        Group {
          LayoutMode: Left;
          Anchor: (Bottom: 10);

          Group #ChannelDetailSwatch {
            Anchor: (Width: 10, Height: 26, Right: 10);
            Background: #7a9cc6;
          }

          Label #ChannelName {
            FlexWeight: 1;
            Style: (FontSize: 20, RenderBold: true, TextColor: #ffffff, VerticalAlignment: Center);
            Text: "Channel";
          }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Bottom: 8);
          Label { Anchor: (Width: 100); Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true); Text: "Type"; }
          Label #ChannelType { FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 13); Text: "-"; }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Bottom: 8);
          Label { Anchor: (Width: 100); Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true); Text: "Prefix"; }
          Label #ChannelPrefix { FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 13); Text: "-"; }
        }

        Group {
          LayoutMode: Left;
          Label { Anchor: (Width: 100); Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true); Text: "Status"; }
          Label #ChannelStatus { FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 13); Text: "-"; }
        }
      }

      Label {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
        Text: "Password (for locked channels)";
      }

      $C.@TextField #PasswordInput {
        @Anchor = (Height: 38, Bottom: 10);
        PlaceholderText: "Leave blank if not needed";
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 44, Bottom: 8);

        $C.@TextButton #SwitchButton {
          @Text = "Speak Here";
          @Anchor = (Width: 170, Right: 8);
        }

        $C.@SecondaryTextButton #ListenButton {
          @Text = "Listen";
          @Anchor = (Width: 130, Right: 8);
        }

        $C.@CancelTextButton #LeaveButton {
          @Text = "Leave";
          @Anchor = (Width: 130);
        }
      }

      $C.@PanelSeparatorFancy {
        @Anchor = (Bottom: 10);
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 44);

        $C.@SecondaryTextButton #OpenTempButton {
          @Text = "Create Temp Channel";
          @Anchor = (Width: 240, Right: 8);
        }

        $C.@TertiaryTextButton #ManageTempButton {
          @Text = "Manage My Channel";
          @Anchor = (Width: 230);
          Visible: false;
        }
      }
    }
  }
}
