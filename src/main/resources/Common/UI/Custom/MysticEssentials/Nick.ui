$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 560, Height: 420);

  #Title {
    Group {
      $C.@Title {
        @Text = "Nickname";
      }
    }
  }

  #Content {
    LayoutMode: Top;

    Group {
      LayoutMode: Left;
      Anchor: (Height: 26, Bottom: 10);
      Label { Anchor: (Width: 130); Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true); Text: "Current"; }
      Label #CurrentNick { FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 13); Text: "-"; }
    }

    $C.@PanelSeparatorFancy {
      @Anchor = (Bottom: 12);
    }

    Label {
      Anchor: (Bottom: 6);
      Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
      Text: "New nickname";
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 38, Bottom: 10);

      $C.@TextField #NickInput {
        FlexWeight: 1;
        PlaceholderText: "Nickname (letters, digits, underscore)";
      }
    }

    Group #ColorRow {
      LayoutMode: Left;
      Anchor: (Height: 38, Bottom: 14);

      Label {
        Anchor: (Width: 130);
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true, VerticalAlignment: Center);
        Text: "Color";
      }

      ColorPickerDropdownBox #NickColor {
        Anchor: (Width: 50, Height: 32);
        Format: Rgb;
        Style: $C.@DefaultColorPickerDropdownBoxStyle;
        Color: #ffffff;
        DisplayTextField: true;
      }
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 44);

      $C.@TextButton #ApplyButton {
        @Text = "Apply";
        @Anchor = (Width: 170, Right: 8);
      }

      $C.@CancelTextButton #RemoveButton {
        @Text = "Remove Nick";
        @Anchor = (Width: 180);
      }
    }
  }
}
