$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 940, Height: 620);

  #Title {
    Group {
      $C.@Title #HeaderTitle {
        @Text = "Edit Vault";
      }

      Label #Subtitle {
        Anchor: (Top: 8, Right: 14, Width: 260, Height: 24);
        Style: (FontSize: 13, TextColor: #96a9be, HorizontalAlignment: End, VerticalAlignment: Center);
        Text: "";
      }
    }
  }

  #Content {
    LayoutMode: Left;

    // ----- Left column: text/colour fields + actions -----
    Group {
      Anchor: (Width: 420);
      LayoutMode: Top;
      Padding: (Right: 16);

      Group #NameRow {
        LayoutMode: Top;
        Anchor: (Bottom: 12);

        Label {
          Anchor: (Bottom: 6);
          Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
          Text: "Name";
        }

        $C.@TextField #NameInput {
          @Anchor = (Height: 38);
          PlaceholderText: "Vault name";
        }
      }

      Group #ColorRow {
        LayoutMode: Left;
        Anchor: (Height: 38, Bottom: 12);

        Label {
          Anchor: (Width: 130);
          Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true, VerticalAlignment: Center);
          Text: "Color";
        }

        ColorPickerDropdownBox #ColorInput {
          Anchor: (Width: 50, Height: 32);
          Format: Rgb;
          Style: $C.@DefaultColorPickerDropdownBoxStyle;
          Color: #7a9cc6;
          DisplayTextField: true;
        }
      }

      Group #IconRow {
        LayoutMode: Top;
        Anchor: (Bottom: 12);

        Label {
          Anchor: (Bottom: 6);
          Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
          Text: "Icon item id";
        }

        $C.@TextField #IconInput {
          @Anchor = (Height: 38);
          PlaceholderText: "e.g. Stone (or pick on the right)";
        }
      }

      Group #DescriptionRow {
        LayoutMode: Top;
        Anchor: (Bottom: 12);

        Label {
          Anchor: (Bottom: 6);
          Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
          Text: "Description";
        }

        $C.@TextField #DescriptionInput {
          @Anchor = (Height: 38);
          PlaceholderText: "Optional lore shown on the card";
        }
      }

      Group {
        FlexWeight: 1;
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 44);

        $C.@TextButton #ApplyButton {
          @Text = "Apply";
          @Anchor = (Width: 150, Right: 8);
        }

        $C.@SecondaryTextButton #ResetButton {
          @Text = "Reset";
          @Anchor = (Width: 130, Right: 8);
        }

        $C.@CancelTextButton #BackButton {
          @Text = "Back";
          @Anchor = (Width: 110);
        }
      }
    }

    // ----- Right column: icon preview + searchable item picker -----
    Group #IconPickerColumn {
      FlexWeight: 1;
      LayoutMode: Top;
      Padding: (Left: 16);

      Group {
        LayoutMode: Left;
        Anchor: (Height: 56, Bottom: 10);

        Group #IconPreviewBorder {
          Anchor: (Width: 52, Height: 52, Right: 12);
          Background: #1a2530;
          Padding: 2;

          ItemSlot #IconPreview {
            Anchor: (Full: 0);
            ShowQualityBackground: true;
            ShowQuantity: false;
          }
        }

        Group {
          LayoutMode: Top;
          FlexWeight: 1;

          Label {
            Anchor: (Height: 20);
            Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true, VerticalAlignment: Center);
            Text: "Choose an icon";
          }

          Label #IconCurrent {
            Anchor: (Height: 18);
            Style: (FontSize: 12, TextColor: #96a9be, VerticalAlignment: Center);
            Text: "";
          }
        }
      }

      $C.@TextField #IconSearch {
        @Anchor = (Height: 34, Bottom: 8);
        PlaceholderText: "Search items...";
      }

      Label #IconEmpty {
        Anchor: (Height: 30);
        Style: (FontSize: 13, TextColor: #9fb0c4, VerticalAlignment: Center);
        Text: "No matching items.";
        Visible: false;
      }

      Group #IconResults {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        Padding: (Right: 10);
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
      }
    }
  }
}
