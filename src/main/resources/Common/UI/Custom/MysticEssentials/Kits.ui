$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 1000, Height: 660);

  #Title {
    Group {
      $C.@Title {
        @Text = "Kits";
      }

      Label #KitCount {
        Anchor: (Top: 8, Right: 14, Width: 160, Height: 24);
        Style: (FontSize: 14, TextColor: #96a9be, HorizontalAlignment: End, VerticalAlignment: Center);
        Text: "";
      }
    }
  }

  #Content {
    LayoutMode: Left;

    Group {
      Anchor: (Width: 360);
      LayoutMode: Top;

      Label #KitEmpty {
        Anchor: (Height: 40);
        Style: (FontSize: 14, TextColor: #9fb0c4, VerticalAlignment: Center, Wrap: true);
        Text: "No kits available.";
        Visible: false;
      }

      Group #KitList {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        Padding: (Right: 10);
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
      }
    }

    Group {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      Padding: (Left: 12);
      ScrollbarStyle: $C.@DefaultScrollbarStyle;

      Group {
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);
        LayoutMode: Top;
        Padding: (Full: 16);
        Anchor: (Bottom: 12);

        Label #KitName {
          Anchor: (Bottom: 8);
          Style: (FontSize: 22, RenderBold: true, TextColor: #ffffff);
          Text: "No Kit";
        }

        Label #KitDescription {
          Anchor: (Bottom: 12);
          Style: (FontSize: 14, TextColor: #96a9be, Wrap: true);
          Text: "";
        }

        Group { LayoutMode: Left; Anchor: (Bottom: 8); Label { Anchor: (Width: 120); Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true); Text: "Status"; } Label #KitStatus { FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 13); Text: "-"; } }
        Group { LayoutMode: Left; Anchor: (Bottom: 8); Label { Anchor: (Width: 120); Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true); Text: "Cooldown"; } Label #KitCooldown { FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 13); Text: "-"; } }
        Group { LayoutMode: Left; Anchor: (Bottom: 8); Label { Anchor: (Width: 120); Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true); Text: "Playtime"; } Label #KitPlaytime { FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 13); Text: "-"; } }
        Group { LayoutMode: Left; Anchor: (Bottom: 8); Label { Anchor: (Width: 120); Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true); Text: "Cost"; } Label #KitCost { FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 13); Text: "-"; } }
        Group { LayoutMode: Left; Label { Anchor: (Width: 120); Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true); Text: "Items"; } Label #KitItems { FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 13); Text: "-"; } }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 44, Bottom: 14);

        $C.@TextButton #ClaimButton {
          @Text = "Claim";
          @Anchor = (Width: 180, Right: 8);
        }

        $C.@SecondaryTextButton #PreviewButton {
          @Text = "Preview";
          @Anchor = (Width: 160);
        }
      }
    }
  }
}
