$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 520, Height: 560);

  #Title {
    Group {
      $C.@Title {
        @Text = "AFK Zones";
      }
    }
  }

  #Content {
    LayoutMode: Top;

    Label {
      Anchor: (Height: 36, Bottom: 8);
      Style: (FontSize: 14, TextColor: #9fb0c4, VerticalAlignment: Center, Wrap: true);
      Text: "Choose a zone to AFK in. You will be sent back here when you return.";
    }

    Label #ZonesEmpty {
      Anchor: (Height: 40);
      Style: (FontSize: 14, TextColor: #9fb0c4, VerticalAlignment: Center, Wrap: true);
      Text: "No AFK zones are available to you.";
      Visible: false;
    }

    Group #ZoneList {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      Padding: (Right: 10);
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 44, Top: 10);

      $C.@SecondaryTextButton #AfkHereButton {
        @Text = "Just AFK Here";
        @Anchor = (Width: 200);
      }
    }
  }
}
