// Row template for the vault editor's icon search results. Appended per item:
//   cmd.append("#IconResults", "MysticEssentials/VaultIconRow.ui")
// and populated by index: cmd.set("#IconResults[i] #Icon.ItemId", "<itemId>").
// Clicking the row selects that item as the vault icon.

Button #Row {
  Anchor: (Height: 40, Bottom: 4);
  LayoutMode: Left;
  Padding: (Left: 8, Right: 8, Top: 3, Bottom: 3);
  Style: (
    Default: (Background: #000000(0.18)),
    Hovered: (Background: #7a9cc6(0.20)),
    Pressed: (Background: #7a9cc6(0.32))
  );

  ItemSlot #Icon {
    Anchor: (Width: 32, Height: 32, Right: 10);
    ShowQualityBackground: true;
    ShowQuantity: false;
  }

  Label #Name {
    FlexWeight: 1;
    Style: (FontSize: 13, TextColor: #d7e1ee, VerticalAlignment: Center);
    Text: "item";
  }
}
