$C = "../Common.ui";

// One row in the Recently Shared Items list. Appended per entry:
//   cmd.append("#RecentList", "MysticEssentials/RecentItemLinkRow.ui")
// then set #Icon.ItemId, #Name.Text, #Meta.Text and bind #InspectButton.

Group #Row {
  Anchor: (Height: 54, Bottom: 6);
  LayoutMode: Left;
  Padding: (Left: 10, Right: 10, Top: 6, Bottom: 6);
  Background: #000000(0.18);

  // ItemSlotButton parent gives the native item tooltip on hover (from #Icon.ItemId).
  ItemSlotButton #IconButton {
    Anchor: (Width: 40, Height: 40, Right: 12);

    ItemSlot #Icon {
      Anchor: (Full: 0);
      ShowQualityBackground: true;
      ShowQuantity: false;
    }
  }

  Group {
    LayoutMode: Top;
    FlexWeight: 1;

    Label #Name {
      Anchor: (Height: 20, Bottom: 2);
      Style: (FontSize: 15, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
      Text: "Item";
    }

    Label #Meta {
      Anchor: (Height: 16);
      Style: (FontSize: 12, TextColor: #9fb0c4, VerticalAlignment: Center);
      Text: "";
    }
  }

  $C.@SecondaryTextButton #InspectButton {
    @Text = "Inspect";
    @Anchor = (Width: 140);
  }
}
