$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 640, Height: 700);

  #Title {
    Group {
      $C.@Title {
        @Text = "Portal";
      }
    }
  }

  #Content {
    LayoutMode: Top;

    Group {
      Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);
      LayoutMode: Top;
      Padding: (Full: 16);
      Anchor: (Bottom: 12);

      Label #PortalHeading {
        Anchor: (Bottom: 2);
        Style: (FontSize: 20, RenderBold: true, TextColor: #ffffff);
        Text: "Portal";
      }

      Label #PortalMeta {
        Anchor: (Bottom: 10);
        Style: (...$C.@DefaultLabelStyle, FontSize: 12);
        Text: "";
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 38, Bottom: 10);

        $C.@TextField #PortalName {
          @Anchor = (Right: 8);
          FlexWeight: 1;
          PlaceholderText: "Display name (optional)";
        }

        $C.@DropdownBox #PortalType {
          @Anchor = (Width: 220);
        }
      }

      Group #WorldSection {
        LayoutMode: Top;

        Label {
          Anchor: (Bottom: 6);
          Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
          Text: "Target world";
        }
        $C.@TextField #TargetWorld {
          @Anchor = (Height: 38, Bottom: 10);
          PlaceholderText: "World name";
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 38, Bottom: 10);

          $C.@SecondaryTextButton #UseLocationToggle {
            @Text = "Exact location: OFF";
            @Anchor = (Width: 220, Right: 8);
          }

          $C.@SmallTertiaryTextButton #HereButton {
            @Text = "Use my position";
            @Anchor = (Width: 170);
          }
        }

        Group #LocationRow {
          LayoutMode: Left;
          Anchor: (Height: 38, Bottom: 10);

          $C.@TextField #PosX {
            @Anchor = (Width: 110, Right: 8);
            PlaceholderText: "X";
          }
          $C.@TextField #PosY {
            @Anchor = (Width: 110, Right: 8);
            PlaceholderText: "Y";
          }
          $C.@TextField #PosZ {
            @Anchor = (Width: 110, Right: 8);
            PlaceholderText: "Z";
          }

          $C.@DropdownBox #Facing {
            @Anchor = (Width: 180);
          }
        }
      }

      Group #ServerSection {
        LayoutMode: Left;
        Anchor: (Height: 38, Bottom: 10);

        $C.@TextField #Host {
          @Anchor = (Right: 8);
          FlexWeight: 1;
          PlaceholderText: "Server host";
        }

        $C.@TextField #Port {
          @Anchor = (Width: 140);
          PlaceholderText: "Port";
        }
      }

      Group #CommandSection {
        LayoutMode: Top;

        Label {
          Anchor: (Bottom: 6);
          Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
          Text: "Commands (separate with ; — use wait <ticks> to pause)";
        }
        $C.@TextField #Command {
          @Anchor = (Height: 38, Bottom: 10);
          PlaceholderText: "spawn {PlayerUsername}; wait 20; give {PlayerUsername} torch";
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 34, Bottom: 10);

          Label {
            Anchor: (Width: 110);
            Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true, VerticalAlignment: Center);
            Text: "Run as";
          }

          $C.@DropdownBox #CommandSender {
            @Anchor = (Width: 200);
          }
        }
      }

      $C.@PanelSeparatorFancy {
        @Anchor = (Bottom: 10);
      }

      Label {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
        Text: "Required permission (empty = everyone)";
      }
      $C.@TextField #Permission {
        @Anchor = (Height: 38, Bottom: 10);
        PlaceholderText: "e.g. mysticessentials.portal.vip";
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 38, Bottom: 6);

        $C.@SecondaryTextButton #MarkerToggle {
          @Text = "Map marker: OFF";
          @Anchor = (Width: 220);
        }
      }

      Group #MarkerRow {
        LayoutMode: Left;
        Anchor: (Height: 38);

        $C.@TextField #MarkerText {
          @Anchor = (Right: 8);
          FlexWeight: 1;
          PlaceholderText: "Marker label";
        }

        $C.@TextField #MarkerIcon {
          @Anchor = (Width: 200);
          PlaceholderText: "Icon (Portal.png)";
        }
      }
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 44, Bottom: 8);

      $C.@TextButton #SaveButton {
        @Text = "Save Portal";
        @Anchor = (Width: 200, Right: 8);
      }

      $C.@CancelTextButton #DeletePortalButton {
        @Text = "Delete Portal";
        @Anchor = (Width: 190);
      }
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 44);

      $C.@TertiaryTextButton #CloseButton {
        @Text = "Close";
        @Anchor = (Width: 140);
      }
    }
  }
}
