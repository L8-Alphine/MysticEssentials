$C = "../Common.ui";

// One single-line statistic row in the Item Details page. Appended per stat:
//   cmd.append("#StatList", "MysticEssentials/ItemStatRow.ui")
// then set #StatLabel.Text and #StatValue.Text. Single-line by design so text
// never overflows onto adjacent rows.

Group #Row {
  Anchor: (Height: 24, Bottom: 4);
  LayoutMode: Left;
  Padding: (Left: 4, Right: 4);

  Label #StatLabel {
    Anchor: (Width: 240);
    Style: (...$C.@DefaultLabelStyle, FontSize: 13, VerticalAlignment: Center);
    Text: "Stat";
  }

  Label #StatValue {
    FlexWeight: 1;
    Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true, HorizontalAlignment: End, VerticalAlignment: Center);
    Text: "";
  }
}
