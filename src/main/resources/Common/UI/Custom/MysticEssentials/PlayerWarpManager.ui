$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 900, Height: 640);

  #Title {
    Group {
      $C.@Title {
        @Text = "My Player Warps";
      }

      Label #ManagerLimit {
        Anchor: (Top: 8, Right: 14, Width: 120, Height: 24);
        Style: (FontSize: 14, TextColor: #96a9be, HorizontalAlignment: End, VerticalAlignment: Center);
        Text: "0 / 0";
      }
    }
  }

  #Content {
    LayoutMode: Left;

    Group {
      Anchor: (Width: 300);
      LayoutMode: Top;

      Label #OwnEmpty {
        Anchor: (Height: 40);
        Style: (FontSize: 14, TextColor: #9fb0c4, VerticalAlignment: Center, Wrap: true);
        Text: "You have no player warps. Use /pwarp create <name>.";
        Visible: false;
      }

      Group #OwnList {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        Padding: (Right: 10);
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
      }
    }

    Group {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      Padding: (Left: 12);
      ScrollbarStyle: $C.@DefaultScrollbarStyle;

      Group {
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);
        LayoutMode: Top;
        Padding: (Full: 16);
        Anchor: (Bottom: 12);

        Label #SelectedName {
          Anchor: (Bottom: 10);
          Style: (FontSize: 20, RenderBold: true, TextColor: #ffffff);
          Text: "No Warp";
        }

        Label {
          Anchor: (Bottom: 6);
          Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
          Text: "Description";
        }

        $C.@TextField #EditDescription {
          @Anchor = (Height: 38, Bottom: 10);
          PlaceholderText: "Describe your warp";
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 38, Bottom: 10);

          $C.@TextField #EditCost {
            @Anchor = (Width: 140, Right: 8);
            PlaceholderText: "Cost";
          }

          $C.@SecondaryTextButton #SaveDetailsButton {
            @Text = "Save Details";
            @Anchor = (Width: 170);
          }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 38, Bottom: 4);

          $C.@TextField #RenameInput {
            @Anchor = (Right: 8);
            FlexWeight: 1;
            PlaceholderText: "New name";
          }

          $C.@SecondaryTextButton #RenameButton {
            @Text = "Rename";
            @Anchor = (Width: 140);
          }
        }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 44, Bottom: 8);

        $C.@TextButton #TeleportButton {
          @Text = "Teleport";
          @Anchor = (Width: 170, Right: 8);
        }

        $C.@SecondaryTextButton #MoveHereButton {
          @Text = "Move Here";
          @Anchor = (Width: 170);
        }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 44, Bottom: 14);

        $C.@CancelTextButton #DeleteButton {
          @Text = "Delete Warp";
          @Anchor = (Width: 200);
        }
      }

      $C.@PanelSeparatorFancy {
        @Anchor = (Bottom: 10);
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 44);

        $C.@TertiaryTextButton #BrowseAllButton {
          @Text = "Browse All Player Warps";
          @Anchor = (Width: 280);
        }
      }
    }
  }
}
