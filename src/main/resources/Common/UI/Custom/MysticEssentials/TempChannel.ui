$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 560, Height: 520);

  #Title {
    Group {
      $C.@Title {
        @Text = "Create Temporary Channel";
      }

      Label #Subtitle {
        Anchor: (Top: 48, Height: 24);
        Style: (
          FontSize: 14,
          TextColor: #96a9be,
          HorizontalAlignment: Center,
          VerticalAlignment: Center
        );
        Text: "Spin up a channel that expires automatically.";
      }
    }
  }

  #Content {
    LayoutMode: Top;

    Group {
      Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);
      LayoutMode: Top;
      Padding: (Full: 16);
      Anchor: (Bottom: 12);

      Label {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
        Text: "Name";
      }
      $C.@TextField #TempNameInput {
        @Anchor = (Height: 40, Bottom: 12);
        PlaceholderText: "e.g. event";
      }

      Label {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
        Text: "Password (optional)";
      }
      $C.@TextField #TempPasswordInput {
        @Anchor = (Height: 40, Bottom: 12);
        PlaceholderText: "Leave blank for open channel";
      }

      Label {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
        Text: "Prefix (optional)";
      }
      $C.@TextField #TempPrefixInput {
        @Anchor = (Height: 40, Bottom: 12);
        PlaceholderText: "e.g. &b[EVENT]";
      }

      Label {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
        Text: "Aliases (optional)";
      }
      $C.@TextField #TempAliasesInput {
        @Anchor = (Height: 40);
        PlaceholderText: "comma,separated,aliases";
      }
    }

    Group #TempButtons {
      LayoutMode: Left;
      Anchor: (Height: 44);

      $C.@TextButton #CreateTempButton {
        @Text = "Create";
        @Anchor = (Right: 8, Width: 160);
      }

      $C.@CancelTextButton #CancelTempButton {
        @Text = "Cancel";
        @Anchor = (Width: 160);
      }
    }
  }
}
