// Row template for the vault list dashboard. Appended per vault by the server:
//   cmd.append("#VaultList", "MysticEssentials/VaultCardRow.ui")
// and populated by index: cmd.set("#VaultList[i] #Name.Text", ...).

Button #Row {
  Anchor: (Height: 66, Bottom: 8);
  LayoutMode: Left;
  Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
  Style: (
    Default: (Background: #000000(0.18)),
    Hovered: (Background: #7a9cc6(0.18)),
    Pressed: (Background: #7a9cc6(0.28))
  );

  Group #Swatch {
    Anchor: (Width: 10, Height: 50, Right: 12);
    Background: #7a9cc6;
  }

  // Real item icon for the vault; the server sets #Icon.ItemId to the icon item.
  ItemSlot #Icon {
    Anchor: (Width: 50, Height: 50, Right: 10);
    ShowQualityBackground: true;
    ShowQuantity: false;
  }

  Group {
    LayoutMode: Top;
    FlexWeight: 1;

    Group {
      LayoutMode: Left;
      Anchor: (Height: 24, Bottom: 2);

      Label #Name {
        FlexWeight: 1;
        Style: (FontSize: 17, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
        Text: "Vault";
      }

      Label #Number {
        Anchor: (Width: 60);
        Style: (FontSize: 15, TextColor: #96a9be, HorizontalAlignment: End, VerticalAlignment: Center);
        Text: "#1";
      }
    }

    Label #Meta {
      Anchor: (Height: 17);
      Style: (FontSize: 12, TextColor: #9fb0c4, VerticalAlignment: Center);
      Text: "";
    }
  }

  Label #Status {
    Anchor: (Width: 110);
    Style: (FontSize: 12, TextColor: #d7e1ee, HorizontalAlignment: End, VerticalAlignment: Center, Wrap: true);
    Text: "";
  }

  Button #EditButton {
    Anchor: (Width: 84, Height: 40, Left: 10);
    Padding: (Left: 8, Right: 8);
    Style: (
      Default: (Background: #7a9cc6(0.22)),
      Hovered: (Background: #7a9cc6(0.36)),
      Pressed: (Background: #7a9cc6(0.5))
    );

    Label {
      Anchor: (Full: 0);
      Style: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
      Text: "Edit";
    }
  }
}
