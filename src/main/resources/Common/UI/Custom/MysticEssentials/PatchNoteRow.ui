$C = "../Common.ui";

// Row template for the patch list in the Patch Notes UI. Appended per note:
//   cmd.append("#NoteList", "MysticEssentials/PatchNoteRow.ui")
// then populated by index: cmd.set("#NoteList[i] #Title.Text", ...).
// The row root is a Button so the whole card selects the patch.

Button #Row {
  Anchor: (Height: 58, Bottom: 8);
  LayoutMode: Left;
  Padding: (Left: 10, Right: 10, Top: 6, Bottom: 6);
  Style: (
    Default: (Background: #000000(0.18)),
    Hovered: (Background: #7fa8d6(0.16)),
    Pressed: (Background: #7fa8d6(0.26))
  );

  Group #Accent {
    Anchor: (Width: 3, Height: 40, Right: 10);
    Background: #7fa8d6;
    Visible: false;
  }

  Group {
    FlexWeight: 1;
    LayoutMode: Top;

    Group {
      LayoutMode: Left;
      Anchor: (Height: 22);

      Label #Unread {
        Anchor: (Width: 14);
        Style: (FontSize: 15, TextColor: #7bd88f, VerticalAlignment: Center);
        Text: "";
      }

      Label #Title {
        FlexWeight: 1;
        Style: (FontSize: 15, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
        Text: "Patch";
      }
    }

    Label #Meta {
      Anchor: (Height: 16);
      Style: (FontSize: 12, TextColor: #96a9be);
      Text: "";
    }
  }

  Group #Pinned {
    Anchor: (Width: 42, Height: 20, Left: 6);
    Background: #7fa8d6(0.22);
    Padding: (Left: 4, Right: 4);
    Visible: false;

    Label {
      Anchor: (Full: 0);
      Style: (FontSize: 10, TextColor: #cfe0f5, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center, VerticalAlignment: Center);
      Text: "Pin";
    }
  }
}
