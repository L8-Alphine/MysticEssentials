$C = "../Common.ui";

// Removal line (red) in the Patch Notes viewer content.
//   cmd.append("#SectionContent", "MysticEssentials/PatchLineRemove.ui")
//   cmd.set("#SectionContent[i] #Line.Text", ...)

Group #Row {
  LayoutMode: Top;
  Anchor: (Height: 20);

  Label #Line {
    Anchor: (Full: 0);
    Style: (FontSize: 14, TextColor: #e07a7a, VerticalAlignment: Center);
    Text: "";
  }
}
