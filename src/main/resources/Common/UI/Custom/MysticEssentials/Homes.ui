$C = "../Common.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 900, Height: 640);

  #Title {
    Group {
      $C.@Title {
        @Text = "My Homes";
      }

      Label #HomeCount {
        Anchor: (Top: 8, Right: 14, Width: 120, Height: 24);
        Style: (FontSize: 14, TextColor: #96a9be, HorizontalAlignment: End, VerticalAlignment: Center);
        Text: "0 / 0";
      }
    }
  }

  #Content {
    LayoutMode: Left;

    Group {
      Anchor: (Width: 300);
      LayoutMode: Top;

      Label #HomesEmpty {
        Anchor: (Height: 40);
        Style: (FontSize: 14, TextColor: #9fb0c4, VerticalAlignment: Center, Wrap: true);
        Text: "You have no homes yet. Use /sethome <name>.";
        Visible: false;
      }

      Group #HomeList {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        Padding: (Right: 10);
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
      }
    }

    Group {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      Padding: (Left: 12);
      ScrollbarStyle: $C.@DefaultScrollbarStyle;

      Group {
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);
        LayoutMode: Top;
        Padding: (Full: 16);
        Anchor: (Bottom: 12);

        Label #SelectedHome {
          Anchor: (Bottom: 8);
          Style: (FontSize: 20, RenderBold: true, TextColor: #ffffff);
          Text: "No Home";
        }

        Group {
          LayoutMode: Left;
          Anchor: (Bottom: 10);
          Label { Anchor: (Width: 100); Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true); Text: "Location"; }
          Label #HomeWorld { FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 13); Text: "-"; }
        }

        Group {
          LayoutMode: Left;
          Anchor: (Height: 38);

          $C.@TextField #RenameInput {
            @Anchor = (Right: 8);
            FlexWeight: 1;
            PlaceholderText: "New name";
          }

          $C.@SecondaryTextButton #RenameButton {
            @Text = "Rename";
            @Anchor = (Width: 140);
          }
        }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 44, Bottom: 8);

        $C.@TextButton #TeleportButton {
          @Text = "Teleport";
          @Anchor = (Width: 170, Right: 8);
        }

        $C.@SecondaryTextButton #MoveHereButton {
          @Text = "Move Here";
          @Anchor = (Width: 170);
        }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 44, Bottom: 14);

        $C.@CancelTextButton #DeleteButton {
          @Text = "Delete Home";
          @Anchor = (Width: 200);
        }
      }

      $C.@PanelSeparatorFancy {
        @Anchor = (Bottom: 10);
      }

      Label {
        Anchor: (Bottom: 6);
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, RenderBold: true);
        Text: "Set a new home at your location";
      }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 38);

        $C.@TextField #NewHomeName {
          @Anchor = (Right: 8);
          FlexWeight: 1;
          PlaceholderText: "Home name";
        }

        $C.@SecondaryTextButton #CreateHomeButton {
          @Text = "Set Home";
          @Anchor = (Width: 150);
        }
      }
    }
  }
}
