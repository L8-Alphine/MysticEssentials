$C = "../Common.ui";

// Row template for the Random Teleport admin overview.
// Appended per profile: cmd.append("#ProfileList", "MysticEssentials/RtpAdminRow.ui").

Group #Row {
  Anchor: (Height: 100, Bottom: 8);
  LayoutMode: Top;
  Padding: (Left: 12, Right: 12, Top: 8, Bottom: 8);
  Background: #000000(0.18);

  Group {
    Anchor: (Height: 30);
    LayoutMode: Left;

    Label #Name {
      FlexWeight: 1;
      Style: (FontSize: 17, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
      Text: "Profile";
    }

    $C.@SmallTertiaryTextButton #ToggleButton {
      @Text = "TOGGLE";
      @Anchor = (Width: 110, Right: 6);
    }

    $C.@SmallSecondaryTextButton #TestButton {
      @Text = "TEST";
      @Anchor = (Width: 90, Right: 6);
    }

    $C.@SmallTertiaryTextButton #CacheButton {
      @Text = "CLEAR CACHE";
      @Anchor = (Width: 140);
    }
  }

  Label #World {
    Anchor: (Height: 20);
    Style: (FontSize: 13, TextColor: #9fb0c4);
    Text: "world";
  }

  Label #Details {
    Anchor: (Height: 20);
    Style: (FontSize: 13, TextColor: #9fb0c4);
    Text: "shape - radius";
  }

  Label #Result {
    Anchor: (Height: 20);
    Style: (FontSize: 13, TextColor: #c6b98f);
    Text: "";
  }
}
