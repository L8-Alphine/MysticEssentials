$C = "../Common.ui";

// Reward slot template for the mail reading pane.
// Appended per attachment: cmd.append("#RewardList", "MysticEssentials/MailReward.ui")
// then cmd.set("#RewardList[i] #Slot.ItemId", ...) and "#RewardList[i] #Qty.Text".

Group #Cell {
  Anchor: (Width: 52, Height: 60, Right: 8);
  LayoutMode: Top;

  Group {
    Anchor: (Width: 52, Height: 52);
    Background: #1a2530;
    Padding: 2;

    ItemSlot #Slot {
      Anchor: (Full: 0);
      ShowQualityBackground: true;
      ShowQuantity: false;
    }
  }

  Label #Qty {
    Anchor: (Height: 14);
    Style: (FontSize: 11, TextColor: #d7e1ee, HorizontalAlignment: Center, VerticalAlignment: Center);
    Text: "x1";
  }
}
